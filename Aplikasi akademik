    // ================================================================
    // MENU UTAMA
    // ================================================================
    static void menuUtama() {
        boolean running = true;
        while (running) {
            System.out.println("══════════════════════════════════════");
            System.out.println("            MENU UTAMA");
            System.out.println("══════════════════════════════════════");
            System.out.println("  1. Manajemen Mahasiswa");
            System.out.println("  2. Manajemen Dosen");
