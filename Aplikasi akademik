    // ================================================================
    // MENU MAHASISWA
    // ================================================================
    static void menuMahasiswa() {
        boolean back = false;
        while (!back) {
            System.out.println("\n--- MENU MAHASISWA ---");
            System.out.println("  1. Tampilkan semua mahasiswa");
            System.out.println("  2. Tambah mahasiswa baru");
            System.out.println("  3. Detail & nilai mahasiswa");
            System.out.println("  4. Daftarkan MK & input nilai");
            System.out.println("  5. Hapus mahasiswa");
            System.out.println("  0. Kembali");
            System.out.print("Pilih: ");
            switch (sc.nextLine().trim()) {
                case "1" -> tampilSemuaMhs();
                case "2" -> tambahMhs();
                case "3" -> detailMhs();
                case "4" -> inputMKNilai();
                case "5" -> hapusMhs();
                case "0" -> back = true;
                default  -> System.out.println("Tidak valid.");
            }
        }
    }

    static void tampilSemuaMhs() {
        System.out.println("\n[Daftar Mahasiswa - " + repoMhs.size() + " data]");
        if (repoMhs.isEmpty()) { System.out.println("  (kosong)"); return; }
        for (int i = 0; i < repoMhs.size(); i++) {
            System.out.println("  [" + i + "] " + repoMhs.get(i).getRingkasan());
        }
    }

    static void tambahMhs() {
        System.out.println("\n--- Tambah Mahasiswa Baru ---");
        System.out.print("NIM     : "); String nim    = sc.nextLine();
        System.out.print("Nama    : "); String nama   = sc.nextLine();
        System.out.print("Alamat  : "); String alamat = sc.nextLine();
        System.out.print("Semester: "); int sem = parseInt(sc.nextLine(), 1);
        System.out.print("Prodi   : "); String prodi  = sc.nextLine();
        MahasiswaProject m = new MahasiswaProject(nim, nama, alamat, sem, prodi);
        repoMhs.tambah(m);
    }

    static void detailMhs() {
        tampilSemuaMhs();
        System.out.print("Pilih index: ");
        int idx = parseInt(sc.nextLine(), -1);
        MahasiswaProject m = repoMhs.get(idx);
        if (m == null) { System.out.println("Index tidak valid."); return; }
        m.tampilInfo();
        m.tampilMataKuliah();
    }

    static void inputMKNilai() {
        tampilSemuaMhs();
        System.out.print("Pilih index mahasiswa: ");
        int idx = parseInt(sc.nextLine(), -1);
        MahasiswaProject m = repoMhs.get(idx);
        if (m == null) { System.out.println("Index tidak valid."); return; }
        System.out.print("Nama Mata Kuliah: "); String mk    = sc.nextLine();
        System.out.print("Nilai (0-100)   : "); int    nilai = parseInt(sc.nextLine(), 0);
        m.daftarMataKuliah(mk);
        m.inputNilai(mk, nilai);
    }

    static void hapusMhs() {
        tampilSemuaMhs();
        System.out.print("Pilih index yang dihapus: ");
        repoMhs.hapus(parseInt(sc.nextLine(), -1));
    }

    // ================================================================
    // MENU DOSEN
    // ================================================================
    static void menuDosen() {
        boolean back = false;
        while (!back) {
            System.out.println("\n--- MENU DOSEN ---");
