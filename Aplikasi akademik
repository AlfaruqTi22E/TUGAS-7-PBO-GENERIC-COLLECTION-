            System.out.println("  0. Kembali");
            System.out.print("Pilih: ");
            switch (sc.nextLine().trim()) {
                case "1" -> tampilSemuaDosen();
                case "2" -> tambahDosen();
                case "3" -> detailDosen();
                case "4" -> tambahMKDosen();
                case "0" -> back = true;
                default  -> System.out.println("Tidak valid.");
            }
        }
    }

    static void tampilSemuaDosen() {
        System.out.println("\n[Daftar Dosen - " + repoDosen.size() + " data]");
        if (repoDosen.isEmpty()) { System.out.println("  (kosong)"); return; }
        for (int i = 0; i < repoDosen.size(); i++) {
            System.out.println("  [" + i + "] " + repoDosen.get(i).getRingkasan());
        }
    }

    static void tambahDosen() {
        System.out.println("\n--- Tambah Dosen Baru ---");
        System.out.print("NIP      : "); String nip     = sc.nextLine();
        System.out.print("Nama     : "); String nama    = sc.nextLine();
        System.out.print("Alamat   : "); String alamat  = sc.nextLine();
        System.out.print("Jabatan  : "); String jabatan = sc.nextLine();
        repoDosen.tambah(new DosenProject(nip, nama, alamat, jabatan));
    }

    static void detailDosen() {
        tampilSemuaDosen();
        System.out.print("Pilih index: ");
        DosenProject d = repoDosen.get(parseInt(sc.nextLine(), -1));
        if (d == null) { System.out.println("Index tidak valid."); return; }
        d.tampilInfo();
        d.tampilMataKuliah();
    }

    static void tambahMKDosen() {
        tampilSemuaDosen();
        System.out.print("Pilih index dosen: ");
        DosenProject d = repoDosen.get(parseInt(sc.nextLine(), -1));
        if (d == null) { System.out.println("Index tidak valid."); return; }
        System.out.print("Nama Mata Kuliah: ");
        d.daftarMataKuliah(sc.nextLine());
    }

    // ================================================================
    // DEMO POLYMORPHISM - referensi Person, objek berbeda
    // ================================================================
    static void demoPolymorphism() {
        System.out.println("\n--- DEMO POLYMORPHISM ---");
        // Polymorphism: referensi Person bisa menampung Mahasiswa maupun Dosen
        // (keduanya extends Person dan implements Akademik)
        Person[] orang = new Person[repoMhs.size() + repoDosen.size()];
        int i = 0;
        for (MahasiswaProject m : repoMhs.getAll()) orang[i++] = m;
        for (DosenProject d     : repoDosen.getAll()) orang[i++] = d;

        System.out.println("Semua Person di sistem [" + orang.length + "]:");
        for (Person p : orang) {
            System.out.println("  -> " + p);    // toString() polymorphic
            p.tampilInfo();                       // tampilInfo() polymorphic
        }
    }

    // ---- Helper ----
    static int parseInt(String s, int def) {
        try { return Integer.parseInt(s.trim()); } catch (Exception e) { return def; }
    }
}
